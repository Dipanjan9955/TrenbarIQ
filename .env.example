# Copy to .env and fill values for local development (do NOT commit .env with real keys)
FLASK_ENV=development
SESSION_SECRET=replace-with-secure-secret
DATABASE_URL=sqlite:///trendbar.db
GEMINI_API_KEY=your_gemini_api_key_here
NEWSAPI_KEY=optional_newsapi_key
UPLOAD_FOLDER=uploads
MAX_UPLOAD_MB=5
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif